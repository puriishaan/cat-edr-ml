# --- Data (large / raw / sensitive) ---
/data/

# --- Results: trained models & checkpoints ---
results/checkpoints/

# --- GRIB / NetCDF binary data files ---
*.grib
*.grib2
*.grb
*.grb2
*.nc
*.nc4
# Allow small example/fixture NetCDF files in tests or notebooks/examples
!tests/fixtures/*.nc
!notebooks/examples/*.nc

# --- Python ---
__pycache__/
*.py[cod]
*.pyo
*.pyd
*.so
*.egg
*.egg-info/
dist/
build/
.eggs/
.Python
pip-wheel-metadata/

# --- Jupyter ---
.ipynb_checkpoints/
*.ipynb_checkpoints

# --- Conda / virtual envs ---
.env
.venv
env/
venv/
*.conda

# --- IDE / OS ---
.DS_Store
.vscode/
.idea/
*.swp
*.swo
*~
Thumbs.db

# --- CDS API key (never commit credentials) ---
.cdsapirc

# --- Runtime logs ---
*.log

